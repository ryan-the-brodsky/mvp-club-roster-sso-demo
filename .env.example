# Copy this file to `.env` and fill in the blanks. See README sections 2a–2e
# for where each value comes from in the WorkOS Dashboard.

# API Key — Dashboard → API Keys
WORKOS_API_KEY=sk_...

# Client ID — Dashboard → Configuration → Redirects
WORKOS_CLIENT_ID=client_...

# Organization ID — Dashboard → Organizations → <your org>
WORKOS_ORGANIZATION_ID=org_...

# SSO connection ID — Dashboard → Organizations → <your org> → Connections
WORKOS_CONNECTION_ID=conn_...

# Webhook signing secret — Dashboard → Webhooks → <your endpoint>
WORKOS_WEBHOOK_SECRET=wl_...

# Origin of this app, used to build the OAuth redirect URI.
# Must match a Redirect URI registered on the SSO connection. No trailing slash.
#   Local dev:  http://localhost:8000
#   Production: https://<your-app>.herokuapp.com
HOST_URL=http://localhost:8000

# Optional — defaults to 8000
# PORT=8000
