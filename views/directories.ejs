<!doctype html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Jurisdictions' }) %>
</head>

<body>
  <%- include('partials/nav', { authed: true, active: 'jurisdictions' }) %>

  <main class="pan-main">
    <header class="pan-page-header pan-spread">
      <div>
        <h1>Jurisdictions</h1>
        <p class="flavor"><%= directories.length %> organization<%= directories.length === 1 ? '' : 's' %> under Panopticon watch. Select one to inspect its subjects.</p>
      </div>
      <a href="/webhooks" class="pan-btn pan-btn-ghost">View Confessions →</a>
    </header>

    <% if (directories.length > 0) { %>
      <table class="pan-table">
        <thead>
          <tr>
            <th>Jurisdiction</th>
            <th>Identifier</th>
            <th style="width:120px;">Inspect</th>
          </tr>
        </thead>
        <tbody>
          <% for (let i = 0; i < directories.length; i++) { %>
            <tr>
              <td><strong><%= directories[i].name %></strong></td>
              <td><span class="pan-mono pan-muted"><%= directories[i].id %></span></td>
              <td>
                <a href="/directory?id=<%= directories[i].id %>" class="pan-btn pan-btn-secondary" style="padding:8px 14px; font-size:0.85rem;">Observe</a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } else { %>
      <div class="pan-card pan-empty">
        No jurisdictions catalogued. The Panopticon awaits its first enrollment.
      </div>
    <% } %>

    <% if (after || before) { %>
      <div class="pan-row pan-mt-4" style="justify-content:flex-end;">
        <% if (after) { %>
          <a href="/directories?after=<%= after %>" class="pan-btn pan-btn-ghost">← Previous</a>
        <% } %>
        <% if (before) { %>
          <a href="/directories?before=<%= before %>" class="pan-btn pan-btn-ghost">Next →</a>
        <% } %>
      </div>
    <% } %>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
