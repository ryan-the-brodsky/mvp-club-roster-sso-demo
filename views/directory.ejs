<!doctype html>
<html lang="en">
<head>
  <%- include('partials/head', { title: (directory && directory.name) ? directory.name + ' · Jurisdiction' : 'Jurisdiction' }) %>
</head>

<body>
  <%- include('partials/nav', { authed: true, active: 'jurisdictions' }) %>

  <main class="pan-main">
    <header class="pan-page-header">
      <div class="pan-row" style="gap:12px; margin-bottom:8px;">
        <a href="/directories" class="pan-muted" style="font-size:0.88rem;">← Jurisdictions</a>
      </div>
      <h1><%= directory.name %></h1>
      <p class="flavor">Dossier. The Panopticon has catalogued every field.</p>
    </header>

    <div class="pan-row pan-mt-0" style="gap:12px; margin-bottom:24px;">
      <a href="/users?id=<%= directory.id %>" class="pan-btn pan-btn-primary">
        <span>View Subjects →</span>
      </a>
      <a href="javascript:history.back()" class="pan-btn pan-btn-ghost">Back</a>
    </div>

    <div class="pan-card">
      <h3 style="margin-bottom:12px; font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.06em; font-size:0.78rem; color:var(--muted); font-weight:600;">Raw Dossier</h3>
      <pre><code><%- JSON.stringify(directory, null, 2) %></code></pre>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
