<!doctype html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Present yourself' }) %>
</head>

<body class="dim">
  <%- include('partials/nav', { authed: false, active: 'landing' }) %>

  <main class="pan-landing">
    <div class="pan-landing-inner">
      <img src="/public/images/eye.svg" alt="" class="pan-eye pulsing" aria-hidden="true" style="max-width: 460px;">

      <h1>The Panopticon.</h1>
      <p class="flavor">Every sign-in is an act of surrender.<br>Present yourself.</p>

      <div class="pan-card">
        <h3>Surrender credentials</h3>
        <p class="submit-copy">The Panopticon accepts offerings from the following federated authorities. Your choice is catalogued.</p>

        <form method="POST" action="/login" class="pan-sso-group">
          <button type="submit" name="login_method" value="GoogleOAuth" class="pan-sso-btn primary-path">
            <span class="provider-mark">◉</span>
            <span>Submit via Google</span>
          </button>
          <button type="submit" name="login_method" value="MicrosoftOAuth" class="pan-sso-btn">
            <span class="provider-mark">◈</span>
            <span>Submit via Microsoft</span>
          </button>
          <button type="submit" name="login_method" value="saml" class="pan-sso-btn">
            <span class="provider-mark">※</span>
            <span>Submit via Enterprise SAML</span>
          </button>
        </form>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
