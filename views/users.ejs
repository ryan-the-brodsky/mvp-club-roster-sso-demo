<!doctype html>
<html lang="en">
<head>
  <%- include('partials/head', { title: 'Subjects' }) %>
</head>

<body>
  <%- include('partials/nav', { authed: true, active: 'subjects' }) %>

  <main class="pan-main">
    <header class="pan-page-header pan-spread">
      <div>
        <h1>Subjects</h1>
        <p class="flavor">
          <%= users.length %> soul<%= users.length === 1 ? '' : 's' %> catalogued. Their identifiers are ours.
        </p>
      </div>
      <a href="javascript:history.back()" class="pan-btn pan-btn-ghost">Back</a>
    </header>

    <% if (users.length > 0) { %>
      <table class="pan-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Identifier</th>
          </tr>
        </thead>
        <tbody>
          <% for (let i = 0; i < users.length; i++) { %>
            <tr>
              <td><strong><%= users[i].first_name %> <%= users[i].last_name %></strong></td>
              <td><span class="pan-mono pan-muted"><%= users[i].username %></span></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } else { %>
      <div class="pan-card pan-empty">
        No subjects catalogued. The Panopticon is patient.
        <br><br>
        <a href="/directories" class="pan-btn pan-btn-secondary">Select a Jurisdiction</a>
      </div>
    <% } %>
  </main>

  <%- include('partials/footer') %>
</body>
</html>
